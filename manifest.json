{
  "manifest_version": 3,
  "name": "ChatGPT Inline QA",
  "version": "1.0.0",
  "description": "Select text in ChatGPT responses to ask inline follow-up questions without affecting the main session",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
